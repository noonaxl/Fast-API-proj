            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Cart has all required fields\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.have.property('items');\r",
                  "    pm.expect(jsonData).to.have.property('total');\r",
                  "    pm.expect(jsonData).to.have.property('items_count');\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Items have correct structure\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    if (jsonData.items.length > 0) {\r",
                  "        var item = jsonData.items[0];\r",
                  "        pm.expect(item).to.have.property('product_id');\r",
                  "        pm.expect(item).to.have.property('name');\r",
                  "        pm.expect(item).to.have.property('price');\r",
                  "        pm.expect(item).to.have.property('quantity');\r",
                  "        pm.expect(item).to.have.property('subtotal');\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Total is calculated correctly\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    var calculatedTotal = 0;\r",
                  "\r",
                  "    jsonData.items.forEach(function(item) {\r",
                  "        calculatedTotal += item.subtotal;\r",
                  "    });\r",
                  "\r",
                  "    pm.expect(jsonData.total).to.eql(calculatedTotal);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Items count is correct\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    var totalQuantity = 0;\r",
                  "\r",
                  "    jsonData.items.forEach(function(item) {\r",
                  "        totalQuantity += item.quantity;\r",
                  "    });\r",
                  "\r",
                  "    pm.expect(jsonData.items_count).to.eql(totalQuantity);\r",
                  "});"
